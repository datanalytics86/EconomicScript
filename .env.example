# ── Base de datos ──────────────────────────────────────────────────────────────
DB_PATH=finance.db

# ── Gmail IMAP ─────────────────────────────────────────────────────────────────
# Servidor IMAP (por defecto Gmail)
IMAP_SERVER=imap.gmail.com
IMAP_PORT=993

# Tu dirección Gmail
IMAP_USER=tu_correo@gmail.com

# Contraseña de aplicación generada en:
# https://myaccount.google.com/apppasswords
# (Requiere tener la verificación en 2 pasos activada)
IMAP_PASSWORD=xxxx xxxx xxxx xxxx

# ── PDF / Cartolas ─────────────────────────────────────────────────────────────
# RUT del titular (usado para abrir PDFs protegidos, ej: 12345678-9)
PDF_PASSWORD=

# ── Otros ─────────────────────────────────────────────────────────────────────
GMAIL_MAX_RESULTS=500
LOG_LEVEL=INFO
