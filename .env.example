# ── Base de datos ──────────────────────────────────────────────────────────────
DB_PATH=finance.db

# ── Gmail IMAP ─────────────────────────────────────────────────────────────────
# Servidor IMAP (por defecto Gmail)
IMAP_SERVER=imap.gmail.com
IMAP_PORT=993

# Tu dirección Gmail
IMAP_USER=tu_correo@gmail.com

# Credenciales OAuth2 — obtenidas ejecutando: python auth_setup.py
# (IMAP_PASSWORD ya no es necesario con OAuth2)
OAUTH_CLIENT_ID=tu_client_id.apps.googleusercontent.com
OAUTH_CLIENT_SECRET=tu_client_secret
OAUTH_REFRESH_TOKEN=tu_refresh_token

# ── PDF / Cartolas ─────────────────────────────────────────────────────────────
# RUT del titular (usado para abrir PDFs protegidos, ej: 12345678-9)
PDF_PASSWORD=

# ── Otros ─────────────────────────────────────────────────────────────────────
GMAIL_MAX_RESULTS=500
LOG_LEVEL=INFO

# ── SMTP — Reporte diario por email ───────────────────────────────────────────
# Correo donde recibirás el resumen diario (puede ser el mismo que IMAP_USER)
SMTP_TO=tu_correo@gmail.com
# Servidor y puerto SMTP (Gmail por defecto, no es necesario cambiar)
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587
# Solo si usas credenciales SMTP distintas a las de IMAP (normalmente no hace falta)
# SMTP_USER=
# SMTP_PASSWORD=
