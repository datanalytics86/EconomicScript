# ── Base de datos ──────────────────────────────────────────────────────────────
DB_PATH=finance.db

# ── Gmail IMAP ─────────────────────────────────────────────────────────────────
IMAP_SERVER=imap.gmail.com
IMAP_PORT=993

# Tu dirección Gmail
IMAP_USER=tu_correo@gmail.com

# App Password de Google (16 caracteres sin espacios)
# Generarla en: myaccount.google.com/apppasswords
IMAP_PASSWORD=abcdabcdabcdabcd

# ── PDF / Cartolas ─────────────────────────────────────────────────────────────
# RUT del titular para abrir PDFs protegidos (ej: 12345678-9). Dejar vacío si no aplica.
PDF_PASSWORD=

# ── Otros ─────────────────────────────────────────────────────────────────────
GMAIL_MAX_RESULTS=500
LOG_LEVEL=INFO

# ── SMTP — Reporte diario por email ───────────────────────────────────────────
# Correo donde recibirás el resumen diario
SMTP_TO=tu_correo@gmail.com
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587
# Solo si usas credenciales SMTP distintas a las de IMAP (normalmente no hace falta)
# SMTP_USER=
# SMTP_PASSWORD=
