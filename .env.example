# ── Base de datos ──────────────────────────────────────────────────────────────
DB_PATH=finance.db

# ── Gmail IMAP ─────────────────────────────────────────────────────────────────
IMAP_SERVER=imap.gmail.com
IMAP_PORT=993

# Tu dirección Gmail (la que recibe notificaciones bancarias)
IMAP_USER=tu_correo@gmail.com

# ── Credenciales OAuth2 ──────────────────────────────────────────────────────
# Obtenidas ejecutando: python auth_setup.py
OAUTH_CLIENT_ID=tu_client_id.apps.googleusercontent.com
OAUTH_CLIENT_SECRET=tu_client_secret
OAUTH_REFRESH_TOKEN=tu_refresh_token

# ── PDF / Cartolas ─────────────────────────────────────────────────────────────
# RUT del titular para abrir PDFs protegidos (ej: 12345678-9). Dejar vacío si no aplica.
PDF_PASSWORD=

# ── Otros ─────────────────────────────────────────────────────────────────────
GMAIL_MAX_RESULTS=500
LOG_LEVEL=INFO

# ── SMTP — Reporte diario por email ───────────────────────────────────────────
# Correo donde recibirás el resumen diario
SMTP_TO=tu_correo@gmail.com
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587
# App Password para envío SMTP (generar en myaccount.google.com/apppasswords)
# SMTP_USER=
# SMTP_PASSWORD=
